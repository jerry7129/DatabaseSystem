<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <%- include('../components/header') %>
        <main>
            <div class="card">
                <h2 class="mb-3"><%= title %></h2>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Book ID</th>
                            <th>Book Title</th>
                            <th>Author</th>
                            <th>Borrow Date</th>
                            <th>Return Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% borrowings.forEach(borrowing => { %>
                            <tr>
                                <td>#<%= borrowing.book_id %></td>
                                <td><%= borrowing.book_title %></td>
                                <td><%= borrowing.book_author %></td>
                                <td><%= borrowing.borrow_date %></td>
                                <td><%= borrowing.return_date || '-' %></td>
                                <td>
                                    <% if (!borrowing.return_date) { %>
                                        <form action="/borrowings/<%= borrowing.id %>/return" method="POST">
                                            <button type="submit" class="btn btn-primary">Return</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <% if (penalty.penalty > 0) { %>
            <div class="card mb-4">
                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                    <h3 class="card-title m-0">
                        Current Penalty Fee: ₩<span><%= penalty.penalty %></span>
                    </h3>
                    <form action="/users/<%= penalty.id %>/pay" method="POST">
                        <button type="submit" class="btn btn-primary">Pay Penalty</button>
                    </form>
                </div>
            </div>
            <% } else if (penalty.penalty === 0) { %>
            <div class="card mb-4">
                <div class="card-body p-3">
                    <h3 class="card-title m-0">
                        Your current penalty fee is ₩0.
                    </h3>
                </div>
            </div>
            <% } %>
        </main>
    </div>
</body>
</html>
